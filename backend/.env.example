GOOGLE_CLOUD_PROJECT=structureiq
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
GCS_BUCKET_NAME=structureiq-docs
VERTEX_LOCATION=us-east1
VERTEX_STANDARDS_INDEX_ID=YOUR_STANDARDS_INDEX_ID
VERTEX_DOCUMENTS_INDEX_ID=YOUR_DOCUMENTS_INDEX_ID
VERTEX_STANDARDS_INDEX_ENDPOINT=YOUR_STANDARDS_ENDPOINT_ID
VERTEX_DOCUMENTS_INDEX_ENDPOINT=YOUR_DOCUMENTS_ENDPOINT_ID
GOOGLE_API_KEY=YOUR_GEMINI_KEY
LANGCHAIN_API_KEY=YOUR_LANGSMITH_KEY
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=structureiq
ENVIRONMENT=development
MAX_FILE_SIZE_MB=100
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K_DOCS=5
RETRIEVAL_TOP_K_STANDARDS=3
CONFIDENCE_THRESHOLD=0.75
